{
  "crons": [
    {
      "path": "/api/cron/health-ping",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "api/chat.ts": { "maxDuration": 60 },
    "api/generate-image.ts": { "maxDuration": 120 },
    "api/upload-audio.ts": { "maxDuration": 60 },
    "api/upload-media.ts": { "maxDuration": 60 },
    "api/opm-process.ts": { "maxDuration": 120 },
    "api/ingest-video.ts": { "maxDuration": 120 },
    "api/transcribe.ts": { "maxDuration": 60 },
    "api/health-check.ts": { "maxDuration": 30 },
    "api/cron/health-ping.ts": { "maxDuration": 30 },
    "api/status-data.ts": { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/((?!api/|assets/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!api/|assets/).*)", "destination": "/index.html" }
  ]
}
